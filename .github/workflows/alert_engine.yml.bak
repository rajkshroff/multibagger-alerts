# ============================================================
# .github/workflows/alert_engine.yml — v3.2
#
# s55: reduced hourly news from 9 crons to 3 (9am, 12:30pm, 3:30pm IST)
# Weekday filter added to all schedule crons.
#
# 3 TRIGGER TYPES:
#   PUSH (CSVs updated)  -> TYPE 1: Action Plan (engine just ran)
#   7:30am Mon-Fri       -> TYPE 2: Morning Brief
#   3 times/day Mon-Fri  -> TYPE 3: News (9am, 12:30pm, 3:30pm IST)
#
# Catalyst scorer (every 5 min) has its own dedicated workflow: catalyst.yml
# ============================================================

name: Multibagger Alert Engine v3

on:
  push:
    paths:
      - 'composite_scores.csv'
      - 'action_language.csv'
      - 'early_alerts.csv'
      - 'watchlist_for_cloud.csv'
      - 'market_intelligence.csv'
    branches: [ main ]

  schedule:
    - cron: '0 2  * * 1-5'   # 7:30am  IST Mon-Fri -- Morning Brief
    - cron: '30 3 * * 1-5'   # 9:00am  IST Mon-Fri -- News slot 1
    - cron: '0  7 * * 1-5'   # 12:30pm IST Mon-Fri -- News slot 2
    - cron: '0 10 * * 1-5'   # 3:30pm  IST Mon-Fri -- News slot 3

  workflow_dispatch:
    inputs:
      mode:
        description: 'Force mode'
        required: false
        default: 'auto'
        type: choice
        options: [auto, test, morning_brief]

jobs:
  alert:
    runs-on: ubuntu-latest
    timeout-minutes: 10
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 1
          token: ${{ secrets.GITHUB_TOKEN }}

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - run: pip install --quiet pandas requests yfinance

      - name: Run Alert Engine
        env:
          TELEGRAM_TOKEN:      ${{ secrets.TELEGRAM_TOKEN }}
          TELEGRAM_BOT_TOKEN:  ${{ secrets.TELEGRAM_TOKEN }}
          TELEGRAM_CHAT_ID:    ${{ secrets.TELEGRAM_CHAT_ID }}
          TELEGRAM_CHAT_IDS:   ${{ secrets.TELEGRAM_CHAT_IDS }}
          TRIGGERED_BY_PUSH:   ${{ github.event_name == 'push' && 'true' || 'false' }}
          FORCE_MORNING_BRIEF: ${{ github.event.inputs.mode == 'morning_brief' && 'true' || 'false' }}
          FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
        run: |
          if [ "${{ github.event.inputs.mode }}" = "test" ]; then
            python cloud_alert_engine.py --test
          else
            python cloud_alert_engine.py
          fi

      - name: Configure git
        run: |
          git config user.email "bot@multibagger-alerts.local"
          git config user.name  "Multibagger Alert Bot"

      - name: Save state (dedup hashes)
        run: |
          git add -f seen_hashes.json morning_brief_sent.json hourly_news_sent.json 2>/dev/null || true
          git diff --staged --quiet || git commit -m "chore: alert state [skip ci]"
          git push || true
        continue-on-error: true
